{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "corepack enable && pnpm --filter @workspace/ouwibo run build",
  "outputDirectory": "artifacts/ouwibo/dist/public",
  "installCommand": "corepack enable && pnpm install --frozen-lockfile",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/((?!api/|_vercel/|assets/|favicon.svg|opengraph.jpg|robots.txt|sitemap.xml|deploy-version.json).*)",
      "destination": "/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.ouwibo.bond"
        }
      ],
      "destination": "https://ouwibo.bond/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/deploy-version.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
