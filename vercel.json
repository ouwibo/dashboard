{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd artifacts/ouwibo && pnpm run build",
  "outputDirectory": "artifacts/ouwibo/dist/public",
  "installCommand": "pnpm install",
  "framework": "vite",
  "functions": {
    "api/**/*.ts": {
      "runtime": "@vercel/node@3"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/((?!api|assets|favicon|opengraph|robots).*)",
      "destination": "/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.ouwibo.bond"
        }
      ],
      "destination": "https://ouwibo.bond/:path*",
      "permanent": true
    }
  ]
}
